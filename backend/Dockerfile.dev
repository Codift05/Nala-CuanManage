FROM node:22-bookworm-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates gosu openssl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY --chown=node:node package.json package-lock.json ./
RUN npm ci

COPY --chown=node:node . .
COPY docker/entrypoint.sh /usr/local/bin/nala-backend-entrypoint
RUN chmod +x /usr/local/bin/nala-backend-entrypoint

EXPOSE 3000

ENTRYPOINT ["/usr/local/bin/nala-backend-entrypoint"]
CMD ["npm", "run", "dev"]
